{
  "expo": {
    "name": "Lacet",
    "slug": "lacet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lacet",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1f14"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Lacet utilise votre position pour trouver des randonnées à proximité.",
        "NSLocationAlwaysUsageDescription": "Lacet utilise votre position pour trouver des randonnées à proximité.",
        "NSCameraUsageDescription": "Lacet utilise la caméra pour votre photo de profil."
      },
      "bundleIdentifier": "com.anonymous.lacet"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.lacet"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-secure-store",
      "expo-notifications",
      "expo-document-picker",
      [
        "@rnmapbox/maps",
        {}
      ]
    ]
  }
}
